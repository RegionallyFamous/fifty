{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Claude",
	"settings": {
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "base",
					"name": "Base",
					"color": "#F5F0E8"
				},
				{
					"slug": "surface",
					"name": "Surface",
					"color": "#FBF7EF"
				},
				{
					"slug": "subtle",
					"name": "Subtle",
					"color": "#ECE5D9"
				},
				{
					"slug": "muted",
					"name": "Muted",
					"color": "#DDD2BE"
				},
				{
					"slug": "border",
					"name": "Border",
					"color": "#92846A"
				},
				{
					"slug": "tertiary",
					"name": "Tertiary",
					"color": "#73685A"
				},
				{
					"slug": "secondary",
					"name": "Secondary",
					"color": "#4D4538"
				},
				{
					"slug": "contrast",
					"name": "Contrast",
					"color": "#1F1B17"
				},
				{
					"slug": "primary",
					"name": "Primary",
					"color": "#1F1B17"
				},
				{
					"slug": "primary-hover",
					"name": "Primary Hover",
					"color": "#3D3527"
				},
				{
					"slug": "accent",
					"name": "Accent",
					"color": "#A04C36"
				},
				{
					"slug": "accent-soft",
					"name": "Accent Soft",
					"color": "#F2D9CC"
				},
				{
					"slug": "success",
					"name": "Success",
					"color": "#3F6B4F"
				},
				{
					"slug": "warning",
					"name": "Warning",
					"color": "#9B6F1F"
				},
				{
					"slug": "error",
					"name": "Error",
					"color": "#9C3A2E"
				},
				{
					"slug": "info",
					"name": "Info",
					"color": "#3A567A"
				}
			]
		},
		"shadow": {
			"presets": [
				{
					"slug": "xs",
					"name": "XS",
					"shadow": "none"
				},
				{
					"slug": "sm",
					"name": "SM",
					"shadow": "none"
				},
				{
					"slug": "md",
					"name": "MD",
					"shadow": "none"
				},
				{
					"slug": "lg",
					"name": "LG",
					"shadow": "none"
				},
				{
					"slug": "xl",
					"name": "XL",
					"shadow": "none"
				},
				{
					"slug": "inset",
					"name": "Inset",
					"shadow": "inset 0 -1px 0 var(--wp--preset--color--border)"
				}
			]
		},
		"custom": {
			"radius": {
				"none": "0",
				"sm": "2px",
				"md": "4px",
				"lg": "6px",
				"xl": "8px",
				"pill": "9999px"
			},
			"line-height": {
				"tight": "1.05",
				"snug": "1.15",
				"normal": "1.55",
				"relaxed": "1.7",
				"loose": "1.85"
			},
			"letter-spacing": {
				"tighter": "-0.025em",
				"tight": "-0.012em",
				"normal": "0",
				"wide": "0.02em",
				"wider": "0.06em",
				"widest": "0.14em"
			},
			"font-weight": {
				"regular": "400",
				"medium": "500",
				"semibold": "600",
				"bold": "700"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
			"fontSize": "var(--wp--preset--font-size--base)",
			"fontWeight": "var(--wp--custom--font-weight--regular)",
			"lineHeight": "var(--wp--custom--line-height--relaxed)",
			"letterSpacing": "var(--wp--custom--letter-spacing--normal)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tight)",
					"lineHeight": "var(--wp--custom--line-height--snug)",
					"textTransform": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--5-xl)",
					"lineHeight": "var(--wp--custom--line-height--tight)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tighter)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3-xl)",
					"lineHeight": "var(--wp--custom--line-height--tight)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tighter)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"letterSpacing": "var(--wp--custom--letter-spacing--wider)",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"letterSpacing": "var(--wp--custom--letter-spacing--widest)",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--tertiary)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--contrast)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "var(--wp--custom--radius--pill)",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"letterSpacing": "var(--wp--custom--letter-spacing--normal)",
					"textTransform": "none"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--sm)",
						"right": "var(--wp--preset--spacing--lg)",
						"bottom": "var(--wp--preset--spacing--sm)",
						"left": "var(--wp--preset--spacing--lg)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent)",
						"text": "var(--wp--preset--color--base)"
					},
					"border": {
						"color": "var(--wp--preset--color--accent)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--accent)",
						"text": "var(--wp--preset--color--base)"
					},
					"border": {
						"color": "var(--wp--preset--color--accent)"
					}
				},
				":active": {
					"color": {
						"background": "var(--wp--preset--color--primary-hover)",
						"text": "var(--wp--preset--color--base)"
					}
				}
			},
			"caption": {
				"typography": {
					"fontStyle": "italic",
					"fontSize": "var(--wp--preset--font-size--xs)"
				},
				"color": {
					"text": "var(--wp--preset--color--tertiary)"
				}
			},
			"cite": {
				"typography": {
					"fontStyle": "italic",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"letterSpacing": "var(--wp--custom--letter-spacing--normal)"
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--5-xl)",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"lineHeight": "var(--wp--custom--line-height--tight)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tighter)",
					"textTransform": "none"
				}
			},
			"core/query-title": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--3-xl)",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tighter)",
					"textTransform": "none"
				}
			},
			"core/post-content": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--md)",
					"lineHeight": "var(--wp--custom--line-height--loose)"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontStyle": "italic",
					"lineHeight": "var(--wp--custom--line-height--snug)"
				},
				"border": {
					"left": {
						"color": "var(--wp--preset--color--accent)",
						"width": "2px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--lg)"
					}
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--2-xl)",
					"fontStyle": "italic",
					"lineHeight": "var(--wp--custom--line-height--snug)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tight)"
				},
				"border": {
					"top": {
						"color": "var(--wp--preset--color--border)",
						"width": "1px",
						"style": "solid"
					},
					"bottom": {
						"color": "var(--wp--preset--color--border)",
						"width": "1px",
						"style": "solid"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--border) "
				},
				"spacing": {
					"margin": {
						"top": "var(--wp--preset--spacing--xl)",
						"bottom": "var(--wp--preset--spacing--xl)"
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"letterSpacing": "var(--wp--custom--letter-spacing--widest)",
					"textTransform": "uppercase"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "var(--wp--custom--font-weight--regular)"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"letterSpacing": "var(--wp--custom--letter-spacing--wider)",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--tertiary)"
				}
			},
			"core/post-author-name": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"letterSpacing": "var(--wp--custom--letter-spacing--wider)",
					"textTransform": "uppercase",
					"fontWeight": "var(--wp--custom--font-weight--medium)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"letterSpacing": "var(--wp--custom--letter-spacing--wider)",
					"textTransform": "uppercase"
				}
			},
			"core/term-name": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tight)"
				}
			},
			"core/term-count": {
				"typography": {
					"fontStyle": "italic",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"text": "var(--wp--preset--color--tertiary)"
				}
			},
			"core/search": {
				"border": {
					"radius": "var(--wp--custom--radius--pill)"
				}
			},
			"woocommerce/product-title": {
				"typography": {
					"fontFamily": "\"New York\", \"Charter\", \"Iowan Old Style\", \"Source Serif 4\", \"Source Serif Pro\", Cambria, Georgia, serif",
					"fontSize": "var(--wp--preset--font-size--md)",
					"fontWeight": "var(--wp--custom--font-weight--regular)",
					"letterSpacing": "var(--wp--custom--letter-spacing--tight)"
				}
			},
			"woocommerce/product-price": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"text": "var(--wp--preset--color--accent)"
				}
			},
			"woocommerce/product-sale-badge": {
				"typography": {
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Inter\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
					"fontSize": "var(--wp--preset--font-size--xs)",
					"letterSpacing": "var(--wp--custom--letter-spacing--wider)",
					"textTransform": "uppercase",
					"fontWeight": "var(--wp--custom--font-weight--medium)"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "var(--wp--custom--radius--pill)"
				}
			}
		}
	}
}
