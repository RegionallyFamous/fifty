{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Obel — WooCommerce demo (Wonders & Oddities)",
    "description": "WordPress + WooCommerce + Obel, pre-loaded with the Wonders & Oddities sample shop and blog.",
    "author": "RegionallyFamous"
  },
  "preferredVersions": { "php": "8.3", "wp": "latest" },
  "features": { "networking": true },
  "login": true,
  "landingPage": "/shop/",
  "plugins": ["woocommerce", "wordpress-importer"],
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/RegionallyFamous/fifty",
        "ref": "main",
        "refType": "branch",
        "path": "obel"
      },
      "options": { "activate": true, "targetFolderName": "obel" }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; delete_transient('_wc_activation_redirect');"
    },
    {
      "step": "writeFile",
      "path": "/wordpress/wo-import.php",
      "data": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/RegionallyFamous/fifty/main/playground/wo-import.php"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp eval-file /wordpress/wo-import.php"
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/RegionallyFamous/wonders-oddities/main/wonders-oddities-content.xml"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp option update show_on_front page && wp option update page_on_front $(wp post list --post_type=page --name=home --field=ids) && wp option update page_for_posts $(wp post list --post_type=page --name=journal --field=ids)"
    },
    {
      "step": "wp-cli",
      "command": "wp menu location assign main-navigation primary || true; wp menu location assign footer-navigation footer || true"
    }
  ]
}
