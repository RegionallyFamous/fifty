{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Dark",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base",        "name": "Base",        "color": "#0F0F10" },
				{ "slug": "surface",     "name": "Surface",     "color": "#17171A" },
				{ "slug": "subtle",      "name": "Subtle",      "color": "#1E1E22" },
				{ "slug": "muted",       "name": "Muted",       "color": "#2A2A2F" },
				{ "slug": "border",      "name": "Border",      "color": "#3A3A40" },
				{ "slug": "tertiary",    "name": "Tertiary",    "color": "#7A7A82" },
				{ "slug": "secondary",   "name": "Secondary",   "color": "#B8B8BD" },
				{ "slug": "contrast",    "name": "Contrast",    "color": "#F5F5F2" },
				{ "slug": "primary",     "name": "Primary",     "color": "#F5F5F2" },
				{ "slug": "primary-hover","name": "Primary Hover","color": "#D9D9D5" },
				{ "slug": "accent",      "name": "Accent",      "color": "#D89668" },
				{ "slug": "accent-soft", "name": "Accent Soft", "color": "#3A2A1F" },
				{ "slug": "success",     "name": "Success",     "color": "#5BB47C" },
				{ "slug": "warning",     "name": "Warning",     "color": "#E0A654" },
				{ "slug": "error",       "name": "Error",       "color": "#E06868" },
				{ "slug": "info",        "name": "Info",        "color": "#6B96D9" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				}
			}
		}
	}
}
