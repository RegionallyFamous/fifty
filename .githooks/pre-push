#!/usr/bin/env bash
# Pre-push gate: same `bin/check.py --all --offline` run as pre-commit,
# plus a drift check that re-runs `bin/append-wc-overrides.py` against
# tmp copies of every theme.json and fails if the output would differ
# from what's checked in.
#
# Why this exists
# ---------------
# This is the backstop for commits made with `git commit --no-verify`
# (which skips the pre-commit hook). It also catches the second-most
# common regression mode: someone edits `bin/append-wc-overrides.py`
# but forgets to re-run it, so the script's source and the actual
# theme.json bytes drift apart.
#
# Why two layers (commit + push)
# ------------------------------
# Pre-commit gives the fast inner-loop signal during local work
# (you find out before the commit lands in your local history).
# Pre-push gives the "did anything sneak through?" backstop right
# before the changes leave the workstation. Server-side CI is the
# third and authoritative layer.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---------------------------------------------------------------------------
# Skip-on-delete fast-path
# ---------------------------------------------------------------------------
# Git's pre-push hook protocol passes one line per ref being pushed on stdin:
#
#     <local-ref> <local-sha> <remote-ref> <remote-sha>
#
# For a deletion (`git push origin --delete <branch>` or
# `git push origin :<branch>`), <local-ref> is empty and <local-sha> is 40
# zeros; the remote pair is the branch being torn down. There is nothing on
# the local side to validate, so running `bin/check.py --all --offline`
# (~10s) and the snap visual gate (~127s/theme) is dead weight that also
# makes routine cleanup ("delete the merged branches GitHub didn't auto-
# prune") block on whatever WIP happens to be sitting in the working tree.
#
# We slurp stdin into an array (so the rest of the hook can still operate
# without it), inspect every line, and exit 0 only when EVERY ref on the
# push is a delete. A mixed push (some creates/updates + some deletes) keeps
# running the full gate — that's the safe default, since the create/update
# half does need to be validated and the cost of the gate is amortised
# across both halves anyway.
#
# Intentionally NOT skipped on delete: branch-protection / hosting-side
# enforcement (server runs its own gates regardless) and the local hooks for
# COMMITS (pre-commit catches anything before the SHA exists locally).
ZERO_SHA="0000000000000000000000000000000000000000"
delete_only=1
saw_any=0
hook_stdin=()
while IFS= read -r line; do
  hook_stdin+=("$line")
  saw_any=1
  # shellcheck disable=SC2206  # word-split is what we want here
  parts=( $line )
  local_sha="${parts[1]:-}"
  if [ "$local_sha" != "$ZERO_SHA" ]; then
    delete_only=0
  fi
done

if [ "$saw_any" = "1" ] && [ "$delete_only" = "1" ]; then
  echo "▸ pre-push: delete-only push (${#hook_stdin[@]} ref(s)) — skipping gate."
  exit 0
fi

echo "▸ pre-push: bin/check.py --all --offline"
# FIFTY_SKIP_UNPUSHED_CHECK=1 tells `bin/check.py` to skip its
# `check_no_unpushed_commits` check ONLY in this hook context. That
# check correctly fails for any commit that hasn't reached origin
# yet, but inside pre-push the commit can't reach origin until the
# hook returns 0, so leaving it on would deadlock every push. CI and
# pre-commit and local invocations leave the env var unset and get
# the full check.
#
# FIFTY_ALLOW_BASELINE_FAILURES=1 -- see the pre-commit hook for the
# full explanation. Short version: demote failures already present
# on origin/main to WARN-BASELINE (still printed, but exit 0) so that
# pre-existing debt doesn't block unrelated feature pushes. New
# regressions not listed in `tests/check-baseline-failures.json`
# still block. CI's theme-gate sets the same env var for parity.
if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_ALLOW_BASELINE_FAILURES=1 \
     python3 bin/check.py --all --offline; then
  echo
  echo "✘ pre-push blocked: bin/check.py reported failures above."
  echo "  Fix locally, commit, then re-push. Don't bypass — CI runs"
  echo "  the same gate and will turn the PR red."
  exit 1
fi

echo "▸ pre-push: append-wc-overrides.py drift check"
# Stash any working-tree edits so the drift check sees committed bytes.
# We compare what re-running the script WOULD do against what's
# actually checked in. The script is sentinel-based, so a clean run
# is a no-op (every chunk's `skip` line). Any '+' line means the
# checked-in theme.json is missing a chunk the script would inject.
DRIFT_OUTPUT="$(python3 bin/append-wc-overrides.py 2>&1)"
if echo "$DRIFT_OUTPUT" | grep -qE '^\+|FAIL'; then
  echo
  echo "✘ pre-push blocked: bin/append-wc-overrides.py is out of sync"
  echo "  with the committed theme.json files. Run:"
  echo "      python3 bin/append-wc-overrides.py"
  echo "  then commit the resulting theme.json changes."
  echo
  echo "  Drift detail:"
  echo "$DRIFT_OUTPUT" | grep -E '^\+|FAIL' | sed 's/^/    /'
  # Restore the theme.json files the script just touched, since the
  # drift check shouldn't itself leave behind a dirty working tree
  # if there was actually drift to fix (we want the committer to do
  # that explicitly).
  git checkout -- '*/theme.json' 2>/dev/null || true
  exit 1
fi

# ---------------------------------------------------------------------------
# Boot-fatal smoke gate (moved here from pre-commit, 2026-04-27)
# ---------------------------------------------------------------------------
# We run `bin/snap.py boot <theme> --cache-state` for any theme whose
# PHP / template / parts / patterns / playground layer was touched by
# commits on this push. The point is to catch "functions.php parse
# error" / "fatals on first render" bugs BEFORE the ~127s visual gate
# burns time on them -- a boot fail makes the visual gate meaningless
# anyway.
#
# Why pre-push and not pre-commit: see .githooks/pre-commit for the
# long version. Short version: pre-commit needs to stay under 20s, and
# the boot smoke is a transient-flake magnet that historically drove
# agents to `FIFTY_SKIP_BOOT_SMOKE=1`-on-reflex. Pre-push absorbs the
# smoke with 3-attempt retry logic so a one-off network blip doesn't
# strand a green commit.
#
# Cost: one Playground boot per touched theme (~20-30s warm /
# ~2-3min cold) × up to 3 retries. On a typical single-theme push
# that's a worst case ~9min; on a steady-state push where the cache
# is warm it's ~30s. The pre-push hook is already willing to spend
# ~127s/theme on the visual gate, so the boot gate is a strict
# prefix.
#
# Escape hatch: FIFTY_SKIP_BOOT_SMOKE=1 git push   (CI still runs it).
if [ "${FIFTY_SKIP_BOOT_SMOKE:-0}" = "1" ]; then
  echo "▸ pre-push: boot smoke SKIPPED (FIFTY_SKIP_BOOT_SMOKE=1)."
else
  # Which themes got PHP/template/part/pattern changes in the commits
  # being pushed? We compare against `origin/main` so a two-commit
  # stack both get checked, not just the tip commit.
  #
  # Fallback: if `origin/main` isn't known (new clone, never fetched),
  # fall back to HEAD~1..HEAD so we at least check the tip commit.
  if git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
    range="origin/main..HEAD"
  else
    range="HEAD~1..HEAD"
  fi
  php_changed_themes="$(
    git diff --name-only --diff-filter=ACMR "$range" \
      -- '*/functions.php' '*/patterns/*.php' '*/templates/*.html' \
         '*/parts/*.html' '*/inc/*.php' '*/playground/*.php' 2>/dev/null \
    | awk -F/ '{print $1}' | sort -u
  )"
  if [ -n "$php_changed_themes" ]; then
    echo "▸ pre-push: PHP/template diffs detected; running boot smoke"
    echo "            on: $(echo "$php_changed_themes" | tr '\n' ' ')"
    echo "            (3 retries per theme; set FIFTY_SKIP_BOOT_SMOKE=1 to bypass)"
    for t in $php_changed_themes; do
      if [ ! -f "$t/theme.json" ]; then
        # The diff touched something that LOOKS like a theme dir but
        # isn't real (e.g. stale worktree, renamed slug). Skip with a
        # one-line note rather than hard-failing, so the push isn't
        # held hostage by a no-longer-existing theme.
        echo "  skip $t (no theme.json; not a real theme)"
        continue
      fi
      attempt=1
      max_attempts=3
      passed=0
      while [ $attempt -le $max_attempts ]; do
        if python3 bin/snap.py boot "$t" --cache-state; then
          passed=1
          break
        fi
        if [ $attempt -lt $max_attempts ]; then
          sleep_s=$(( attempt * 10 ))
          echo "  boot smoke attempt $attempt/$max_attempts for $t failed; retrying in ${sleep_s}s…"
          sleep "$sleep_s"
        fi
        attempt=$(( attempt + 1 ))
      done
      if [ "$passed" != "1" ]; then
        echo
        echo "✘ pre-push blocked: boot smoke for $t failed $max_attempts times in a row."
        echo "  This is usually a real bug (PHP parse error, call to"
        echo "  undefined function, bad blueprint, unseeded playground"
        echo "  content). See tmp/$t-boot.json for the latest verdict."
        echo "  If you're convinced it's a transient network flake and"
        echo "  want CI to decide: FIFTY_SKIP_BOOT_SMOKE=1 git push"
        exit 1
      fi
    done
    echo "✓ pre-push: boot smoke green for all touched themes."
  fi
fi

echo "▸ pre-push: bin/snap.py check --changed (visual + axe gate)"
# Phase 1 (`phase1-prepush-visual`) of the closed-loop plan: pre-push
# now boots Playground for any theme touched by the diff and runs
# the visual + axe gate. This is what catches the cascade-loss /
# placeholder-contrast / overflow regressions that the static gate
# above can't see (they're paint-time, not source-time).
#
# Cost: one Playground cold-boot per touched theme (~127s). Pre-commit
# remains static-only because that cost is intolerable on every save;
# pre-push is the right place because pushing happens 1-2 orders of
# magnitude less often than committing.
#
# Escape hatch: FIFTY_SKIP_VISUAL_PUSH=1 git push   (use sparingly;
# CI runs the same gate and will turn the PR red).
if [ "${FIFTY_SKIP_VISUAL_PUSH:-0}" = "1" ]; then
  echo "  SKIPPED (FIFTY_SKIP_VISUAL_PUSH=1)."
else
  if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_SKIP_EVIDENCE_FRESHNESS=1 \
        python3 bin/snap.py check --changed; then
    echo
    echo "✘ pre-push blocked: bin/snap.py check --changed reported"
    echo "  visual or accessibility regressions. Fix locally, re-snap,"
    echo "  commit, then re-push. To bypass once (NOT recommended):"
    echo "      FIFTY_SKIP_VISUAL_PUSH=1 git push"
    exit 1
  fi

  # The visual gate above re-shot every changed theme, so there is
  # now snap evidence on disk for them. Re-run the static gate with
  # FIFTY_REQUIRE_SNAP_EVIDENCE=1 -- only on the changed themes --
  # to make sure NONE of them sneaked through the no-snap SKIP path
  # in `check_no_serious_axe_in_recent_snaps`. Parity with CI's
  # `snap-evidence-gate` job in .github/workflows/check.yml.
  changed="$(python3 -c '
import sys, pathlib
sys.path.insert(0, "bin")
from snap import _changed_themes
print(" ".join(_changed_themes("origin/main") or []))
')"
  if [ -n "$changed" ]; then
    echo "▸ pre-push: bin/check.py per-changed-theme (snap evidence required)"
    for t in $changed; do
      if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_SKIP_EVIDENCE_FRESHNESS=1 \
            FIFTY_ALLOW_BASELINE_FAILURES=1 \
            FIFTY_REQUIRE_SNAP_EVIDENCE=1 python3 bin/check.py "$t" --offline; then
        echo
        echo "✘ pre-push blocked: $t failed the snap-evidence-required gate."
        echo "  Re-shoot with: python3 bin/snap.py shoot $t"
        echo "  then re-run: bin/check.py $t --offline"
        exit 1
      fi
    done
  fi
fi

echo "✓ pre-push: all gates green."

# ---------------------------------------------------------------------------
# Auto-arm GitHub auto-merge (--squash) on the matching PR
# ---------------------------------------------------------------------------
# The repo's branch protection on `main` requires the 7 CI status checks to
# pass but no longer requires a manual review. Arming auto-merge here means
# every PR squash-merges itself the instant CI clears, with no second
# `gh pr merge` step needed after the push.
#
# Idempotent: if auto-merge is already armed on the PR, this no-ops. If no
# PR exists yet for the branch (e.g. the very first push, before
# `gh pr create`), it silently skips — the next push (or a subsequent run
# of this hook) will arm it once the PR exists.
#
# Convenience-only: failures here NEVER block the push. The push has
# already passed every gate above; whether auto-merge gets armed is
# strictly a UX nicety and a stuck `gh` shouldn't strand a green push.
#
# Escape hatch: FIFTY_SKIP_AUTO_MERGE=1 git push   (e.g. when you want to
# review a PR's diff yourself before merging, or hold a PR open for
# discussion). Pushes to `main` itself, to `HEAD`, or with no resolvable
# branch name skip auto-arming automatically.
if [ "${FIFTY_SKIP_AUTO_MERGE:-0}" != "1" ] && command -v gh >/dev/null 2>&1; then
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [ -n "$current_branch" ] \
     && [ "$current_branch" != "HEAD" ] \
     && [ "$current_branch" != "main" ]; then
    pr_json="$(gh pr view "$current_branch" \
                  --json number,autoMergeRequest,state \
                  2>/dev/null || true)"
    if [ -n "$pr_json" ]; then
      pr_state="$(echo "$pr_json" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("state",""))' 2>/dev/null || echo "")"
      pr_num="$(echo "$pr_json" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("number",""))' 2>/dev/null || echo "")"
      already="$(echo "$pr_json" | python3 -c 'import json,sys;print("yes" if json.load(sys.stdin).get("autoMergeRequest") else "no")' 2>/dev/null || echo "no")"
      if [ "$pr_state" = "OPEN" ] && [ -n "$pr_num" ]; then
        if [ "$already" = "yes" ]; then
          echo "▸ pre-push: PR #$pr_num auto-merge already armed."
        else
          echo "▸ pre-push: arming auto-merge --squash on PR #$pr_num"
          if ! gh pr merge "$pr_num" --auto --squash >/dev/null 2>&1; then
            echo "  (could not arm auto-merge; not blocking push)"
          fi
        fi
      fi
    fi
  fi
fi
