#!/usr/bin/env bash
# Pre-push gate: same `bin/check.py --all --offline` run as pre-commit,
# plus a drift check that re-runs `bin/append-wc-overrides.py` against
# tmp copies of every theme.json and fails if the output would differ
# from what's checked in.
#
# Why this exists
# ---------------
# This is the backstop for commits made with `git commit --no-verify`
# (which skips the pre-commit hook). It also catches the second-most
# common regression mode: someone edits `bin/append-wc-overrides.py`
# but forgets to re-run it, so the script's source and the actual
# theme.json bytes drift apart.
#
# Why two layers (commit + push)
# ------------------------------
# Pre-commit gives the fast inner-loop signal during local work
# (you find out before the commit lands in your local history).
# Pre-push gives the "did anything sneak through?" backstop right
# before the changes leave the workstation. Server-side CI is the
# third and authoritative layer.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---------------------------------------------------------------------------
# Skip-on-delete fast-path
# ---------------------------------------------------------------------------
# Git's pre-push hook protocol passes one line per ref being pushed on stdin:
#
#     <local-ref> <local-sha> <remote-ref> <remote-sha>
#
# For a deletion (`git push origin --delete <branch>` or
# `git push origin :<branch>`), <local-ref> is empty and <local-sha> is 40
# zeros; the remote pair is the branch being torn down. There is nothing on
# the local side to validate, so running `bin/check.py --all --offline`
# (~10s) and the snap visual gate (~127s/theme) is dead weight that also
# makes routine cleanup ("delete the merged branches GitHub didn't auto-
# prune") block on whatever WIP happens to be sitting in the working tree.
#
# We slurp stdin into an array (so the rest of the hook can still operate
# without it), inspect every line, and exit 0 only when EVERY ref on the
# push is a delete. A mixed push (some creates/updates + some deletes) keeps
# running the full gate — that's the safe default, since the create/update
# half does need to be validated and the cost of the gate is amortised
# across both halves anyway.
#
# Intentionally NOT skipped on delete: branch-protection / hosting-side
# enforcement (server runs its own gates regardless) and the local hooks for
# COMMITS (pre-commit catches anything before the SHA exists locally).
ZERO_SHA="0000000000000000000000000000000000000000"
delete_only=1
saw_any=0
hook_stdin=()
while IFS= read -r line; do
  hook_stdin+=("$line")
  saw_any=1
  # shellcheck disable=SC2206  # word-split is what we want here
  parts=( $line )
  local_sha="${parts[1]:-}"
  if [ "$local_sha" != "$ZERO_SHA" ]; then
    delete_only=0
  fi
done

if [ "$saw_any" = "1" ] && [ "$delete_only" = "1" ]; then
  echo "▸ pre-push: delete-only push (${#hook_stdin[@]} ref(s)) — skipping gate."
  exit 0
fi

echo "▸ pre-push: bin/check.py --all --offline"
# FIFTY_SKIP_UNPUSHED_CHECK=1 tells `bin/check.py` to skip its
# `check_no_unpushed_commits` check ONLY in this hook context. That
# check correctly fails for any commit that hasn't reached origin
# yet, but inside pre-push the commit can't reach origin until the
# hook returns 0, so leaving it on would deadlock every push. CI and
# pre-commit and local invocations leave the env var unset and get
# the full check.
if ! FIFTY_SKIP_UNPUSHED_CHECK=1 python3 bin/check.py --all --offline; then
  echo
  echo "✘ pre-push blocked: bin/check.py reported failures above."
  echo "  Fix locally, commit, then re-push. Don't bypass — CI runs"
  echo "  the same gate and will turn the PR red."
  exit 1
fi

echo "▸ pre-push: append-wc-overrides.py drift check"
# Stash any working-tree edits so the drift check sees committed bytes.
# We compare what re-running the script WOULD do against what's
# actually checked in. The script is sentinel-based, so a clean run
# is a no-op (every chunk's `skip` line). Any '+' line means the
# checked-in theme.json is missing a chunk the script would inject.
DRIFT_OUTPUT="$(python3 bin/append-wc-overrides.py 2>&1)"
if echo "$DRIFT_OUTPUT" | grep -qE '^\+|FAIL'; then
  echo
  echo "✘ pre-push blocked: bin/append-wc-overrides.py is out of sync"
  echo "  with the committed theme.json files. Run:"
  echo "      python3 bin/append-wc-overrides.py"
  echo "  then commit the resulting theme.json changes."
  echo
  echo "  Drift detail:"
  echo "$DRIFT_OUTPUT" | grep -E '^\+|FAIL' | sed 's/^/    /'
  # Restore the theme.json files the script just touched, since the
  # drift check shouldn't itself leave behind a dirty working tree
  # if there was actually drift to fix (we want the committer to do
  # that explicitly).
  git checkout -- '*/theme.json' 2>/dev/null || true
  exit 1
fi

echo "▸ pre-push: bin/snap.py check --changed (visual + axe gate)"
# Phase 1 (`phase1-prepush-visual`) of the closed-loop plan: pre-push
# now boots Playground for any theme touched by the diff and runs
# the visual + axe gate. This is what catches the cascade-loss /
# placeholder-contrast / overflow regressions that the static gate
# above can't see (they're paint-time, not source-time).
#
# Cost: one Playground cold-boot per touched theme (~127s). Pre-commit
# remains static-only because that cost is intolerable on every save;
# pre-push is the right place because pushing happens 1-2 orders of
# magnitude less often than committing.
#
# Escape hatch: FIFTY_SKIP_VISUAL_PUSH=1 git push   (use sparingly;
# CI runs the same gate and will turn the PR red).
if [ "${FIFTY_SKIP_VISUAL_PUSH:-0}" = "1" ]; then
  echo "  SKIPPED (FIFTY_SKIP_VISUAL_PUSH=1)."
else
  if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_SKIP_EVIDENCE_FRESHNESS=1 \
        python3 bin/snap.py check --changed; then
    echo
    echo "✘ pre-push blocked: bin/snap.py check --changed reported"
    echo "  visual or accessibility regressions. Fix locally, re-snap,"
    echo "  commit, then re-push. To bypass once (NOT recommended):"
    echo "      FIFTY_SKIP_VISUAL_PUSH=1 git push"
    exit 1
  fi
fi

echo "✓ pre-push: all gates green."
