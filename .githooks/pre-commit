#!/usr/bin/env bash
# Pre-commit gate: run `bin/check.py --all --offline` against every theme
# in the monorepo. Blocks the commit if any check fails.
#
# Why this exists
# ---------------
# We've shipped two regressions where a checked-in CSS chunk drifted
# past `check_no_important` because nothing automated ran the gate
# before the commit landed. The full check suite is fast (~3s × 5
# themes ≈ 15s on this machine) so running it on every commit is a
# trade we're happy to make.
#
# How to bypass (don't, unless you know exactly why)
# --------------------------------------------------
#   git commit --no-verify
# That bypass is caught by the .githooks/pre-push backstop and by
# the GitHub Actions workflow at .github/workflows/check.yml. Both
# run the same gate, so a --no-verify commit still can't reach main.
#
# Activation
# ----------
# This hook only fires if `git config core.hooksPath` points at
# .githooks/ in the repo root. Run `python3 bin/install-hooks.py`
# once after cloning to set that.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Skip when there are no staged changes (e.g. `git commit --amend
# --no-edit` with nothing else queued).
if git diff --cached --quiet; then
  exit 0
fi

echo "▸ pre-commit: bin/check.py --all --offline (catches !important leaks, hex drift, microcopy collisions, layout duplication, …)"
# FIFTY_SKIP_UNPUSHED_CHECK=1 silences the `check_no_unpushed_commits`
# check inside this hook only. That check is designed to catch "agent
# committed a fix but never pushed it" in CI / standalone runs, but
# inside pre-commit it deadlocks the loop: any prior unpushed commit
# (or this very commit, on `git commit --amend`) would block every
# new commit until the user manually pushes. CI keeps the env var
# unset and gets the full check, so the safety net is preserved
# where it actually matters.
#
# FIFTY_ALLOW_BASELINE_FAILURES=1 consults
# `tests/check-baseline-failures.json` (regenerated from origin/main)
# and demotes any failure already present on main from FAIL (exit-1)
# to WARN-BASELINE (still printed, but harmless). The point is to
# stop pre-existing debt from blocking unrelated feature commits --
# if you're fixing the Foundry return-to-cart button, you should not
# also have to fix Foundry's 2.14:1 hover contrast ratio on the same
# commit just to land your change. New regressions (pairs NOT in the
# JSON) still block normally. CI on `main` is the source of truth
# for what debt exists; see the JSON's `_doc` field for the
# regeneration workflow.
if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_ALLOW_BASELINE_FAILURES=1 \
     python3 bin/check.py --all --offline; then
  echo
  echo "✘ pre-commit blocked: bin/check.py reported failures above."
  echo "  Fix the failures and re-stage, or pass --no-verify if you"
  echo "  know why (the pre-push hook + CI will still run the same"
  echo "  gate, so don't expect --no-verify to land your commit on main)."
  exit 1
fi

echo "✓ pre-commit: all themes pass."

# ---------------------------------------------------------------------------
# Boot-fatal smoke gate (Tier 1.1, pre-100-themes hardening)
# ---------------------------------------------------------------------------
# When a commit touches a theme's PHP or template layer we run
# `bin/snap.py boot <theme> --cache-state` to catch the "my functions.php
# has a syntax error" / "template-loader fatals on every request" class
# of bug BEFORE it reaches CI. The smoke probes four public URLs and
# scans both the response bodies and the server log for PHP fatals /
# parse errors / uncaught critical errors.
#
# Cost: ~20-30s per theme on a warm --cache-state dir, ~2-3 min cold.
# We ONLY fire when the diff actually touches PHP or template sources
# (functions.php, template files, pattern PHP, plugin shims), so a
# CSS-only or theme.json-only commit keeps the fast ~15s pre-commit
# round-trip. Setting FIFTY_SKIP_BOOT_SMOKE=1 bypasses the gate for
# the cases where the cold-cache penalty is genuinely unaffordable
# (rebase-heavy sessions, offline commits). Like --no-verify the
# bypass is visible to CI, where the smoke still runs.
if [ "${FIFTY_SKIP_BOOT_SMOKE:-0}" != "1" ]; then
  # Staged files that can crash the theme at runtime. We intentionally
  # do NOT include theme.json, style.css, or *.json blueprints because
  # those don't execute PHP and won't produce the kind of fatal the
  # gate is designed to catch. Block pattern PHP (patterns/*.php) +
  # block template parts (parts/*.html) + functions.php + templates/
  # because all of them can syntax-error the theme or trip a call to
  # undefined function.
  php_changed_themes="$(
    git diff --cached --name-only --diff-filter=ACMR \
      -- '*/functions.php' '*/patterns/*.php' '*/templates/*.html' \
         '*/parts/*.html' '*/inc/*.php' '*/playground/*.php' 2>/dev/null \
    | awk -F/ '{print $1}' | sort -u
  )"
  if [ -n "$php_changed_themes" ]; then
    echo
    echo "▸ pre-commit: PHP/template diffs detected; running boot smoke"
    echo "             on: $(echo "$php_changed_themes" | tr '\n' ' ')"
    echo "             (set FIFTY_SKIP_BOOT_SMOKE=1 to bypass)"
    for t in $php_changed_themes; do
      # Safety filter: skip slugs that aren't real themes (e.g. the diff
      # touched bin/ or tests/). `snap.py boot` would 404 on the
      # blueprint anyway but the error message is clearer here.
      if [ ! -f "$t/theme.json" ]; then
        continue
      fi
      if ! python3 bin/snap.py boot "$t" --cache-state; then
        echo
        echo "✘ pre-commit blocked: boot smoke failed for $t."
        echo "  See tmp/$t-boot.json for the probe + log scan verdict."
        echo "  Bypass with FIFTY_SKIP_BOOT_SMOKE=1 (CI still runs it)."
        exit 1
      fi
    done
    echo "✓ pre-commit: boot smoke green for all touched themes."
  fi
fi

# Soft warning (rule #20): if we're committing from the shared root
# while agent worktrees are active, surface a heads-up. Always exits
# 0; it does NOT block the commit.
if [ -x bin/agent-worktree.py ]; then
  python3 bin/agent-worktree.py warn-if-racing || true
fi
