#!/usr/bin/env bash
# Pre-commit gate: run `bin/check.py --all --offline` against every theme
# in the monorepo. Blocks the commit if any check fails.
#
# Why this exists
# ---------------
# We've shipped two regressions where a checked-in CSS chunk drifted
# past `check_no_important` because nothing automated ran the gate
# before the commit landed. The full check suite is fast (~3s × 5
# themes ≈ 15s on this machine) so running it on every commit is a
# trade we're happy to make.
#
# How to bypass (don't, unless you know exactly why)
# --------------------------------------------------
#   git commit --no-verify
# That bypass is caught by the .githooks/pre-push backstop and by
# the GitHub Actions workflow at .github/workflows/check.yml. Both
# run the same gate, so a --no-verify commit still can't reach main.
#
# Activation
# ----------
# This hook only fires if `git config core.hooksPath` points at
# .githooks/ in the repo root. Run `python3 bin/install-hooks.py`
# once after cloning to set that.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Skip when there are no staged changes (e.g. `git commit --amend
# --no-edit` with nothing else queued).
if git diff --cached --quiet; then
  exit 0
fi

if [ "${FIFTY_AGENT_RESCUE:-0}" = "1" ]; then
  echo "▸ pre-commit: AGENT RESCUE active (FIFTY_AGENT_RESCUE=1)."
  echo "  Skipping local scoped gate so the repair branch can be committed;"
  echo "  CI remains authoritative and must pass before merge."
  exit 0
fi

if [ "${FIFTY_DESIGN_PREPUBLISH:-0}" = "1" ]; then
  echo "▸ pre-commit: design prepublish active (FIFTY_DESIGN_PREPUBLISH=1)."
  echo "  Skipping scoped theme checks until snap/screenshot evidence exists;"
  echo "  the final design commit and push run the full gate."
  exit 0
fi

echo "▸ pre-commit: resolving staged scope"
scope="$(python3 bin/changed-scope.py --staged --format shell)"
themes="$(printf '%s\n' "$scope" | sed -n 's/^themes=//p')"
all_themes_required="$(printf '%s\n' "$scope" | sed -n 's/^all_themes_required=//p')"
has_repo_infra="$(printf '%s\n' "$scope" | sed -n 's/^has_repo_infra_changes=//p')"
docs_only="$(printf '%s\n' "$scope" | sed -n 's/^docs_only=//p')"
reason="$(printf '%s\n' "$scope" | sed -n 's/^reason=//p')"

if [ "$docs_only" = "true" ]; then
  echo "✓ pre-commit: docs/mockups-only change; theme gate skipped."
elif [ "$all_themes_required" = "true" ]; then
  echo "▸ pre-commit: framework change detected ($reason); running lint smoke."
  echo "  Fleet-health remains available in CI/manual runs; local commit will not"
  echo "  require snap evidence for every old theme."
  if ! python3 bin/lint.py; then
    echo
    echo "✘ pre-commit blocked: lint failed for framework changes."
    echo "  Use FIFTY_AGENT_RESCUE=1 only for repair commits that need CI arbitration."
    exit 1
  fi
  echo "✓ pre-commit: framework lint passed."
elif [ -n "$themes" ]; then
  echo "▸ pre-commit: bin/check.py --changed --staged --offline ($reason)"
# FIFTY_SKIP_UNPUSHED_CHECK=1 silences the `check_no_unpushed_commits`
# check inside this hook only. That check is designed to catch "agent
# committed a fix but never pushed it" in CI / standalone runs, but
# inside pre-commit it deadlocks the loop: any prior unpushed commit
# (or this very commit, on `git commit --amend`) would block every
# new commit until the user manually pushes. CI keeps the env var
# unset and gets the full check, so the safety net is preserved
# where it actually matters.
#
# FIFTY_ALLOW_BASELINE_FAILURES=1 consults
# `tests/check-baseline-failures.json` (regenerated from origin/main)
# and demotes any failure already present on main from FAIL (exit-1)
# to WARN-BASELINE (still printed, but harmless). The point is to
# stop pre-existing debt from blocking unrelated feature commits --
# if you're fixing the Foundry return-to-cart button, you should not
# also have to fix Foundry's 2.14:1 hover contrast ratio on the same
# commit just to land your change. New regressions (pairs NOT in the
# JSON) still block normally. CI on `main` is the source of truth
# for what debt exists; see the JSON's `_doc` field for the
# regeneration workflow.
  if ! FIFTY_SKIP_UNPUSHED_CHECK=1 FIFTY_ALLOW_BASELINE_FAILURES=1 \
       python3 bin/check.py --changed --staged --offline; then
    echo
    echo "✘ pre-commit blocked: scoped theme checks reported failures above."
    echo "  Fix the failures and re-stage, or use FIFTY_AGENT_RESCUE=1"
    echo "  for an auditable repair commit that CI will arbitrate."
    exit 1
  fi
  echo "✓ pre-commit: scoped theme gate passed."
elif [ "$has_repo_infra" = "true" ]; then
  echo "▸ pre-commit: repo-infra change detected ($reason); running lint smoke."
  if ! python3 bin/lint.py; then
    echo
    echo "✘ pre-commit blocked: lint failed for repo-infra changes."
    echo "  Use FIFTY_AGENT_RESCUE=1 only for repair commits that need CI arbitration."
    exit 1
  fi
  echo "✓ pre-commit: repo-infra lint passed."
else
  echo "✓ pre-commit: no theme or repo-infra gate needed ($reason)."
fi

# ---------------------------------------------------------------------------
# Boot-fatal smoke gate MOVED to pre-push
# ---------------------------------------------------------------------------
# Previously this hook ran `bin/snap.py boot <theme> --cache-state` for
# every theme whose PHP/template/part/patterns file was staged. Reality
# check, based on the `agent/batch-20260427-4d9c9b-basalt` merge-prep
# session in late April 2026:
#
#   1. The smoke's cold-cache cost (~2-3 min/theme) dominated the
#      pre-commit loop for any diff that touched PHP. An agent fixing a
#      contrast issue would edit functions.php, ship a commit, wait 3
#      minutes for the smoke to pass, find one more string to touch,
#      wait another 3 minutes, repeat. The fast inner-loop signal this
#      hook is supposed to provide evaporated.
#   2. The smoke was a false-positive magnet for transient flakes
#      (download timeouts, stale Playground cache, WC CSV parse hiccup
#      on boot). Humans learned to reach for FIFTY_SKIP_BOOT_SMOKE=1
#      on reflex and the gate's actual defect-detection value fell off
#      a cliff.
#   3. The same boot happens, transitively, inside pre-push's
#      `bin/snap.py check --changed` visual+axe gate -- so the only
#      class of bug pre-commit's boot smoke caught that pre-push's
#      visual gate didn't was "theme fatals on / before any page
#      renders". That's a real but tiny failure surface, and it's
#      better handled once at push time with retry logic.
#
# The boot smoke now runs inside pre-push with up to 3 retries (see
# .githooks/pre-push) so a one-off network flake doesn't trigger
# reflex --no-verify. Pre-commit stays under 20s even on PHP-touching
# commits, which keeps the agent loop fast.

# Soft warning (rule #20): if we're committing from the shared root
# while agent worktrees are active, surface a heads-up. Always exits
# 0; it does NOT block the commit.
if [ -x bin/agent-worktree.py ]; then
  python3 bin/agent-worktree.py warn-if-racing || true
fi
