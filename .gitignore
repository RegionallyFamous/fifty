# Snap framework: ephemeral artefacts.
# `tmp/` holds the latest-shoot PNGs, mutated blueprints, server logs,
# and per-pixel diff PNGs. Regenerated on every `bin/snap.py shoot|diff`.
# The committed counterpart (the human-reviewed reference set) lives at
# `tests/visual-baseline/` and is NOT ignored.
tmp/

# Snap framework: lazily vendored axe-core blob (~540KB).
# Downloaded on first `bin/snap.py shoot` from a version-pinned CDN URL
# (see AXE_VERSION in bin/snap.py) and cached locally. Re-downloads if
# missing; safe to delete.
bin/vendor/

# macOS
.DS_Store

# Node (only present if a contributor runs npm install for any reason)
node_modules/

# Python tooling caches
__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/

# Editor scratch
*.swp
*.swo
.vscode/
.idea/

# Local secrets (never commit)
.env
.env.local
